#!/usr/bin/env bash
if [ -e "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh" ]; then
    . "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh"
elif [ -e "$HOME/.nix-profile/etc/profile.d/nix.sh" ]; then
    . "$HOME/.nix-profile/etc/profile.d/nix.sh"
fi
export QT_QUICK_BACKEND=software

# Default variables
CACHE_FOLDER="$HOME/.cache/ml4w/hyprland-dotfiles"
CACHE_FILE="$CACHE_FOLDER/current_wallpaper"
DEFAULT_WALLPAPER="$HOME/.config/ml4w/wallpapers/default.jpg"

# Colors for UI
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# --- UI Functions (Redirected to stderr) ---
info() { echo -e "${GREEN}[INFO]${NC} $1" >&2; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1" >&2; }
error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }

# Ensure that cache folder exists
mkdir -p $HOME/.cache

# Set Wallpaper
mkdir -p $CACHE_FOLDER
if [ ! -f $CACHE_FILE ]; then
    touch $CACHE_FILE
    echo "$DEFAULT_WALLPAPER" > "$CACHE_FILE"
    info "Cache file created"
fi

WALLPAPER_APP="quickshell"
if [ -f $HOME/.config/ml4w/settings/wallpaper-app ]; then
    WALLPAPER_APP=$(cat $HOME/.config/ml4w/settings/wallpaper-app)
fi

if [ "$WALLPAPER_APP" == "quickshell" ]; then
    ~/.config/ml4w/scripts/ml4w-wallpaper "$(cat $CACHE_FILE)" &
fi

# Start Quickshell
killall qs
sleep 0.5
nohup qs > /dev/null 2>&1 &
disown
sleep 0.5

# Start ML4W Settings App
nohup env PROFILE="com.ml4w.dotfiles" qs -p $HOME/.local/share/ml4w-dotfiles-settings/quickshell > /dev/null 2>&1 &
disown
info "ML4W Dotfiles Settings started"

# Start Quickshell Overview
nohup qs -p $HOME/.config/quickshell/overview > /dev/null 2>&1 &
disown
info "Quickshell Overview started"

# Start ML4W Welcome App
if [ ! -f $HOME/.cache/ml4w-welcome-autostart ]; then
    sleep 3
    qs ipc call welcome toggle
    info "ML4W Welcome started"
else
    info "ML4W Welcome disabled"
fi

# Start wayvnc VNC Server
systemctl --user restart wayvnc
info "wayvnc VNC service restarted via systemd"
